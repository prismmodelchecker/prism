// Tests for path properties whose evaluation in simulation
// needs to look beyond a deadlock state in the model

// RESULT: 1.0
P=? [ F>N+5 x=N ]

// RESULT: 0.0
P=? [ F>N+5 x=N-1 ]

// RESULT: 1.0
P=? [ F<=N+5 x=N ]

// RESULT: 1.0
P=? [ F[N+1,N+2] x>0 ]

// RESULT: 0.0
P=? [ x=0 U[N+1,N+2] x>0 ]
